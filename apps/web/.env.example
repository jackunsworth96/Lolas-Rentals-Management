# Copy to .env and fill in values. (.env is gitignored.)

VITE_API_URL=

# Supabase Dashboard → Project Settings → API:
# - Project URL → VITE_SUPABASE_URL
# - "anon" "public" key under Project API keys → VITE_SUPABASE_ANON_KEY
# Never put the service_role key in the web app.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry (optional — leave blank to disable)
VITE_SENTRY_DSN=
