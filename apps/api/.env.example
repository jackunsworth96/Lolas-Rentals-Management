# Supabase
SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-sb-publishable-key-here
SUPABASE_SERVICE_ROLE_KEY=your-sb-secret-key-here


# JWT
JWT_SECRET=your-jwt-secret-here


# Google Sheets (background sync only)
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGIN=your-allowed-origin-here

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
NOTIFICATION_EMAIL=staff@lolasrentals.com
NOTIFICATION_EMAIL_FROM=noreply@lolasrentals.com
DRIVER_EMAIL=driver@example.com

# External APIs
AERODATABOX_API_KEY=your-aerodatabox-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
